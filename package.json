{
  "name": "react-datepicker-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/plus"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:packages && vite build",
    "build:packages": "tsc -b packages/core/tsconfig.build.json packages/plus/tsconfig.build.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 -c apps/storybook/.storybook",
    "build-storybook": "storybook build -c apps/storybook/.storybook",
    "test": "vitest",
    "test:async-validation": "vitest run packages/plus/src/testing/asyncValidationHttp.test.ts packages/plus/src/components/DatePicker/DatePicker.test.tsx packages/plus/src/components/DateRangePicker/DateRangePicker.test.tsx",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "test:async-validation:browser": "vitest --config=vitest.browser.config.ts packages/plus/src/components/DatePicker/DatePicker.browser.test.tsx packages/plus/src/components/DateRangePicker/DateRangePicker.browser.test.tsx",
    "test:browser:install": "playwright install chromium",
    "verify": "vitest run && npm run test:async-validation:browser && vite build",
    "docs": "typedoc"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "date-fns": "^3.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-docs": "10.0.8",
    "@storybook/react-vite": "10.0.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/browser-playwright": "^4.0.15",
    "autoprefixer": "^10.4.0",
    "baseline-browser-mapping": "^2.10.0",
    "jsdom": "^27.2.0",
    "msw": "^2.12.11",
    "postcss": "^8.4.0",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.0",
    "typedoc": "^0.25.13",
    "typescript": "^5.0.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
